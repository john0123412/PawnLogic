# ════════════════════════════════════════════════════════════
# PawnLogic 1.1 — .env 配置文件
#
# 使用方法：cp .env.example .env，然后填入你需要的 Key
# 本文件【只存放密钥】，服务启动参数在 mcp_configs.json
#
# 安全提示：.env 已加入 .gitignore，切勿提交到版本库！
# ════════════════════════════════════════════════════════════


# ── 【从这里开始】推荐首选 ────────────────────────────────
# DeepSeek — 国内直连，Key 申请最简单
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=


# ── 【可选】其他 AI 服务 ──────────────────────────────────
# Anthropic Claude（需要境外支付方式）
ANTHROPIC_API_KEY=

# OpenAI（需要代理）
OPENAI_API_KEY=

# 通义千问（阿里云百炼，国内直连）
QWEN_API_KEY=

# 智谱 GLM（国内直连，有视觉模型）
ZHIPU_API_KEY=

# 硅基流动（国内直连，低成本推理）
SILICON_API_KEY=

# Moonshot Kimi（超长上下文）
MOONSHOT_API_KEY=

# Groq（极速，境外服务）
GROQ_API_KEY=

# 小米 MiMo（国内直连）
# 注意：xiaomi 属于 custom provider，定义在 ~/.pawnlogic/custom_providers.json
#       而非内置 provider；首次使用前先用 /provider add 或运行向导添加。
XIAOMI_API_KEY=


# ── 【MCP 工具密钥】─────────────────────────────────────
# 以下密钥由 mcp_configs.json 中的服务声明引用
# 仅在使用对应 MCP 工具时需要填写

# Tavily（网络搜索 MCP 服务）
TAVILY_API_KEY=

# Browserbase（云浏览器 MCP 服务）
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=


# ── 【高级】本地 Ollama ────────────────────────────────
# 本地部署时按需修改，无需 Key
# LOCAL_API_URL=http://localhost:11434/v1/chat/completions


# ── 【系统设置】────────────────────────────────────────
# 覆盖默认启动模型（可选）
# PAWNLOGIC_DEFAULT_MODEL=ds-chat

# 日志级别（DEBUG / INFO / WARNING）
# PAWNLOGIC_LOG_LEVEL=INFO
