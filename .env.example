# PawnLogic .env template.
#
# Copy this file to ~/.pawnlogic/.env or run `pawn` and use the first-run
# wizard. This file stores secrets only. MCP server declarations belong in
# mcp_configs.json.
#
# Security: never commit .env files.


# Recommended default provider.
# DeepSeek key URL: https://platform.deepseek.com
DEEPSEEK_API_KEY=


# Optional AI providers.
# Anthropic Claude.
ANTHROPIC_API_KEY=

# OpenAI.
OPENAI_API_KEY=

# Qwen.
QWEN_API_KEY=

# Zhipu GLM.
ZHIPU_API_KEY=

# SiliconFlow.
SILICON_API_KEY=

# Moonshot Kimi.
MOONSHOT_API_KEY=

# Groq.
GROQ_API_KEY=

# Xiaomi MiMo. Xiaomi is a custom provider, not a built-in provider.
# Add it with `/provider add` or the interactive provider panel before use.
XIAOMI_API_KEY=


# MCP tool keys. Only required when the matching MCP server is enabled.

# Tavily search MCP.
TAVILY_API_KEY=

# Browserbase cloud browser MCP.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=


# Advanced: local Ollama or another local OpenAI-compatible endpoint.
# LOCAL_API_URL=http://localhost:11434/v1/chat/completions


# Optional runtime settings.
# PAWNLOGIC_DEFAULT_MODEL=ds-chat

# Log level: DEBUG / INFO / WARNING.
# PAWNLOGIC_LOG_LEVEL=INFO
