# =================================================================
# NousAgent Project - Git Ignore Configuration
# =================================================================

# --- Sensitive data (core protection) ---
.env
.env.*
*.Key
*.key
*.token
*.pem
*.crt
*.p12
id_rsa*
id_ed25519*
.envrc
mcp_configs.json
custom_providers.smoke.json
secrets.json
secrets.yaml
*.secret

# --- Python environments and caches ---
.venv/
venv/
ENV/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# --- AI tool caches and config ---
.aider*
.aiderignore
.cline/
.thought
.pawnlogic_index/

# --- Editors and IDEs (JetBrains/VS Code) ---
.idea/
.vscode/
*.swp
*.bak
*.user
*.code-workspace

# --- Build artifacts and distributions ---
build/
dist/
*.egg-info/
*.spec

# --- Operating system temporary files ---
.DS_Store
Thumbs.db

# --- CI caches ---
.ruff_cache/
htmlcov/
.coverage

# --- History and backups (avoid committing filter-repo or manual backups) ---
*.gitbackup-*
*.git-backup-*
.git-rewrite/
*-original/
*.orig
*.rej

# --- Project-specific excludes (logs and temporary data) ---
logs/
*.log
temp/
*.pyc
.claude/
pwn_debug.md
iscc_work/
