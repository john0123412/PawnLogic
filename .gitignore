# =================================================================
# NousAgent Project - Git Ignore Configuration
# =================================================================

# --- 敏感数据 (核心保护) ---
.env
.env.*
*.Key
*.key
*.token
*.pem
*.crt
*.p12
id_rsa*
id_ed25519*
.envrc
mcp_configs.json
custom_providers.smoke.json
secrets.json
secrets.yaml
*.secret

# --- Python 环境与缓存 ---
.venv/
venv/
ENV/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# --- AI 工具缓存与配置 ---
.aider*
.aiderignore
.cline/
.thought
.pawnlogic_index/

# --- 编辑器与 IDE (JetBrains/VS Code) ---
.idea/
.vscode/
*.swp
*.bak
*.user
*.code-workspace

# --- 构建产物与分发 ---
build/
dist/
*.egg-info/
*.spec

# --- 操作系统临时文件 ---
.DS_Store
Thumbs.db

# --- CI 缓存 ---
.ruff_cache/
htmlcov/
.coverage

# --- 历史与备份（防 filter-repo / 手动 backup 误提）---
*.gitbackup-*
*.git-backup-*
.git-rewrite/
*-original/
*.orig
*.rej

# --- 项目特定排除 (如日志或临时数据) ---
logs/
*.log
temp/
*.pyc
.claude/
pwn_debug.md
iscc_work/
