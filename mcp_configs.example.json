{
  "mcpServers": {
    "tavily": {
      "command": "node",
      "args": ["/home/user/.npm-global/lib/node_modules/tavily-mcp/build/index.js"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "playwright": {
      "command": "node",
      "args": ["/home/user/.npm-global/lib/node_modules/@playwright/mcp/cli.js"]
    },
    "filesystem": {
      "command": "node",
      "args": [
        "/home/user/.npm-global/lib/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "/tmp"
      ]
    }
  }
}
